{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": ["base"],
      "displayName": "Debug",
      "description": "Debug build using the system default C++ compiler",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": ["base"],
      "displayName": "Release",
      "description": "Release build using the system default C++ compiler",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release-stats",
      "inherits": ["base"],
      "displayName": "Release with search stats",
      "description": "Release build with search stats diagnostics enabled",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "LATRUNCULI_SEARCH_STATS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "jobs": 0
    },
    {
      "name": "release",
      "configurePreset": "release",
      "jobs": 0
    },
    {
      "name": "release-stats",
      "configurePreset": "release-stats",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-stats",
      "configurePreset": "release-stats",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
